# Replace with your own values.

# Shared by both central and relay.
NODE_ENV=dev
CONTACT_EMAIL=team@shellular.dev
CORS_ORIGIN=https://app.shellular.dev, shellular://
# HMAC secret used to sign (central) and verify (relay) WebSocket tickets.
WS_TOKEN_SECRET=replace-with-at-least-32-random-characters

# ── Central (auth / DB / token mint / presence registry) ──────────────────────
CENTRAL_HOST=0.0.0.0
CENTRAL_PORT=6969

# OAuth
# Public API origin used when building provider callback URLs.
AUTH_PUBLIC_BASE_URL=https://server.shellular.dev
# Deep link used after OAuth completes. The mobile app listens for this URL.
AUTH_APP_CALLBACK_URL=shellular://auth-callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Sign in with Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# ── Relay (DB-free WebSocket relay) ───────────────────────────────────────────
RELAY_HOST=127.0.0.1
RELAY_PORT=6970
# Where the relay reports to — the central API base above.
CENTRAL_API_URL=http://127.0.0.1:6969
# The public HTTP(S) origin clients reach this relay at — its identity in central's
# live fleet (central health-checks it; the CLI derives ws/wss from http/https).
# In dev this is OPTIONAL: if unset it's derived as http://<RELAY_HOST>:<RELAY_PORT>.
# In prod it is REQUIRED and must be https, e.g. https://in.shellular.dev
# RELAY_PUBLIC_URL=https://in.shellular.dev
# PostHog
POSTHOG_KEY=    

# Shared secret authenticating relay→central registration + presence reports.
# Required for the relay to register and for presence/stats; both sides must match.
RELAY_SECRET=replace-with-at-least-16-random-characters