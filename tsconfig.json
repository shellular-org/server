{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"ignoreDeprecations": "6.0",
		"paths": {
			"@central/*": ["./central/*"],
			"@relay/*": ["./relay/*"],
			"@shared/*": ["./shared/*"]
		}
	},
	"include": [
		"central/**/*",
		"relay/**/*",
		"shared/**/*",
		"scripts/**/*",
		"index.d.ts"
	],
	"exclude": ["node_modules"]
}
